{
  "name": "post-validator",
  "version": "1.0.0",
  "description": "Microservicio de validación de posts - Proyecto Integrador TYVS - Universidad de La Sabana",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "ts-node-dev --respawn src/index.ts",
